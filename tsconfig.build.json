{
	"extends": "@companion-module/tools/tsconfig/node22/recommended-esm.json",
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules/**", "src/**/*spec.ts", "src/**/*test.ts", "src/**/__tests__/**", "src/**/__mocks__/**"],
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"paths": {
			"*": ["./node_modules/*"]
		},
		"lib": ["ES2024"],

		// TypeScript >6.0 enforces this; opt in early for forwards-compatibility.
		"alwaysStrict": true,

		// We rely on eslint @typescript-eslint/no-unused-vars to forbid unused
		// variables (without limiting them just to names starting with '_'), so
		// we turn off this error.
		"noUnusedLocals": false
	}
}
